{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "cli": {
    "analytics": "3540d647-97b5-4ed1-a618-b0081bfd0135"
  },
  "newProjectRoot": "projects",
  "projects": {
    "web-app": {
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "configurations": {
            "production": {
              "budgets": [
                {
                  "maximumError": "5mb",
                  "maximumWarning": "2mb",
                  "type": "initial"
                },
                {
                  "maximumError": "10kb",
                  "maximumWarning": "6kb",
                  "type": "anyComponentStyle"
                }
              ],
              "buildOptimizer": true,
              "extractLicenses": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "namedChunks": false,
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "vendorChunk": false
            }
          },
          "options": {
            "assets": [
              "src/favicon.ico",
              "src/assets",
              {
                "glob": "**/*",
                "input": "src/assets/tinymce",
                "output": "tinymce/"
              }
            ],
            "index": "src/index.html",
            "main": "src/main.ts",
            "outputPath": "dist/web-app",
            "polyfills": "src/polyfills.ts",
            "scripts": [
              "node_modules/jquery/dist/jquery.js",
              "node_modules/bootstrap/dist/js/bootstrap.js",
              "node_modules/alertifyjs/build/alertify.js",
              "src/assets/js/app.min.js",
              "src/assets/tinymce/tinymce.min.js"
            ],
            "styles": [
              "node_modules/bootstrap/dist/css/bootstrap.css",
              "node_modules/font-awesome/css/font-awesome.css",
              "node_modules/alertifyjs/build/css/alertify.css",
              "src/assets/css/ionicons/css/ionicons.css",
              "src/assets/css/AdminLTE.min.css",
              "src/assets/css/skins/_all-skins.min.css",
              "src/assets/css/busy.css",
              "src/assets/css/checkbox.css",
              "node_modules/ng-busy/src/style/busy.css",
              "node_modules/@circlon/angular-tree-component/css/angular-tree-component.css",
              "node_modules/ng2-daterangepicker/assets/daterangepicker.css",
              "src/styles.css",
              "node_modules/ngx-bar-rating/themes/br-default-theme.scss",
              "node_modules/ngx-bar-rating/themes/br-horizontal-theme.scss",
              "node_modules/ngx-bar-rating/themes/br-vertical-theme.scss",
              "node_modules/ngx-bar-rating/themes/br-movie-theme.scss",
              "node_modules/ngx-bar-rating/themes/br-square-theme.scss"
            ],
            "tsConfig": "tsconfig.app.json",
            "vendorChunk": true,
            "extractLicenses": false,
            "buildOptimizer": false,
            "sourceMap": true,
            "optimization": false,
            "namedChunks": true
          },
          "defaultConfiguration": ""
        },
        "e2e": {
          "builder": "@angular-devkit/build-angular:protractor",
          "configurations": {
            "production": {
              "devServerTarget": "web-app:serve:production"
            }
          },
          "options": {
            "devServerTarget": "web-app:serve",
            "protractorConfig": "e2e/protractor.conf.js"
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "web-app:build"
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "browserTarget": "web-app:build:production"
            }
          },
          "options": {
            "browserTarget": "web-app:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "karmaConfig": "karma.conf.js",
            "main": "src/test.ts",
            "polyfills": "src/polyfills.ts",
            "scripts": [],
            "styles": [
              "src/styles.css"
            ],
            "tsConfig": "tsconfig.spec.json"
          }
        }
      },
      "prefix": "app",
      "projectType": "application",
      "root": "",
      "schematics": {},
      "sourceRoot": "src"
    }
  },
  "version": 1
}